{
  "title": "MoneyFlow Overview",
  "uid": "moneyflow-overview",
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "초당 HTTP 요청 수 (RPS)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(http_server_requests_seconds_count[1m])) by (job)",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 2,
      "title": "응답 시간 P95 (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[1m])) by (le, job)) * 1000",
          "legendFormat": "P95 {{job}}"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket[1m])) by (le, job)) * 1000",
          "legendFormat": "P99 {{job}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 3,
      "title": "Saga 상태별 건수",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 6 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(transfer_saga_status_total{status=\"COMPLETED\"}) or vector(0)",
          "legendFormat": "COMPLETED"
        },
        {
          "datasource": "Prometheus",
          "expr": "sum(transfer_saga_status_total{status=\"FAILED\"}) or vector(0)",
          "legendFormat": "FAILED"
        },
        {
          "datasource": "Prometheus",
          "expr": "sum(transfer_saga_status_total{status=\"COMPENSATED\"}) or vector(0)",
          "legendFormat": "COMPENSATED"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal" }
    },
    {
      "id": 4,
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(kafka_consumer_fetch_manager_records_lag) by (topic)",
          "legendFormat": "{{topic}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 5,
      "title": "Redis 캐시 히트율",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 14, "w": 6, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(redis_commands_processed_total{command=\"get\"}[1m]) / (rate(redis_commands_processed_total{command=\"get\"}[1m]) + rate(redis_commands_processed_total{command=\"miss\"}[1m]) + 0.001) * 100",
          "legendFormat": "Hit Rate %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "JVM 힙 메모리 사용량",
      "type": "timeseries",
      "gridPos": { "x": 18, "y": 14, "w": 6, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "jvm_memory_used_bytes{area=\"heap\"} / jvm_memory_max_bytes{area=\"heap\"} * 100",
          "legendFormat": "{{job}} heap %"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 7,
      "title": "DB Connection Pool 사용률",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "hikaricp_connections_active / hikaricp_connections_max * 100",
          "legendFormat": "{{job}} pool %"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "id": 8,
      "title": "HTTP 에러율 (4xx / 5xx)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"4..\"}[1m])) by (job)",
          "legendFormat": "4xx {{job}}"
        },
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[1m])) by (job)",
          "legendFormat": "5xx {{job}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    }
  ]
}
